      "direction": "knowledge -> source"
    },
    {
      "type": "cite_from",
      "description": "Knowledge statement cites a source section.",
      "display": "tooltip-only",
      "direction": "knowledge -> source"
    },
    {
      "type": "support",
      "description": "Knowledge is supported by source evidence.",
